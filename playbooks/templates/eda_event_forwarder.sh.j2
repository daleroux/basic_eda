#!/bin/bash
# Generated by Ansible for {{ inventory_hostname }}

AUTH_B64="{{ (eda_basic_user ~ ':' ~ eda_basic_pass) | b64encode }}"

while IFS= read -r line; do
  curl -sk -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: Basic ${AUTH_B64}" \
    -d "$line" \
    "https://{{ aap_fqdn }}/eda-event-streams/api/eda/v1/external_event_stream/{{ eda_UUID }}/post/"
done